\section{Between-Path Regions}

\subsection{Shading Between Two Lattice Paths}

Shade the region between lower and upper bounds:

\begin{minted}[fontsize=\small]{latex}
\lpDeclarePath{LB1}{010101}
\lpDeclarePath{UB1}{111000}
\shadeBetweenBits{010101}{111000}{LB1}{UB1}
\shadeBetween[fill=yellow!40{LB1}{UB1}
\drawLatticePath[red, very thick]{LB1}
\drawLatticePath[blue, very thick]{UB1}
\end{minted}

\begin{center}
\begin{tikzpicture}[scale=1.3]
  \lpDeclarePath{LB1}{010101}
  \lpDeclarePath{UB1}{111000}
  \shadeBetweenBits{010101}{111000}{LB1}{UB1}
  
  % Shade first
  \shadeBetween[fill=yellow!40{LB1}{UB1}
  
  % Then draw paths on top
  \drawLatticePath[red, very thick]{LB1}
  \drawLatticePath[blue, very thick]{UB1}
  
  \draw[gray, very thin] (0,0) grid (6,6);
\end{tikzpicture}
\quad
\begin{tikzpicture}[scale=1.3]
  \lpDeclarePath{LB1}{010101}
  \lpDeclarePath{UB1}{111000}
  \shadeBetweenBits{010101}{111000}{LB1}{UB1}
  
  % Shade first
  \shadeBetween[fill=yellow!40{LB1}{UB1}
  
  % Then draw paths on top
  \drawLatticePath[red, very thick, lplpath/label upmarks]{LB1}
  \drawLatticePath[blue, very thick, lplpath/label upmarks]{UB1}
  
  \draw[gray, very thin] (0,0) grid (6,6);
\end{tikzpicture}
\end{center}

